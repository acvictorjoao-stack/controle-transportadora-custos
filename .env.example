# Supabase — obrigatório para o FleetControl
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — necessário para provisionar administradores (Portal Master)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# URL pública do app (links de acesso das empresas, OAuth e metadados)
NEXT_PUBLIC_APP_URL="https://fleetcontrol.com"
